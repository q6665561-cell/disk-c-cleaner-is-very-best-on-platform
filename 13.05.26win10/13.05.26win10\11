def is_any_browser_installed():
    """Check the Windows Registry to see if any common browsers are installed."""
    browsers = [
        ("Google Chrome", "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\chrome.exe"),
        ("Mozilla Firefox", "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\firefox.exe"),
        ("Microsoft Edge", "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\msedge.exe"),
    ]
    for name, key_path in browsers:
        try:
            winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, key_path)
            log.info(f"Browser found: {name}")
            return True
        except FileNotFoundError:
            continue
    return False

def download_chrome_installer():
    """Download the latest Google Chrome standalone installer."""
    log.info("--- No Browser Found. Downloading Chrome Installer ---")
    # Official Google Chrome offline installer URL (stable channel)
    chrome_url = "https://dl.google.com/tag/s/installdataindex/update2/installers/ChromeStandaloneSetup64.exe"
    public_desktop = "C:\\Users\\Public\\Desktop"
    installer_path = os.path.join(public_desktop, "Chrome_Installer.exe")

    # Create a README file explaining what to do
    readme_path = os.path.join(public_desktop, "INSTALL_CHROME.txt")
    try:
        with open(readme_path, "w") as f:
            f.write("IMPORTANT: No web browser was detected on your system.\n")
            f.write("A Google Chrome installer has been downloaded for you.\n")
            f.write("Please run 'Chrome_Installer.exe' to install Chrome and get online.\n")
        log.info(f"Created README file: {readme_path}")
    except Exception as e:
        log.error(f"Could not create README: {e}")

    # Download the installer
    try:
        log.info(f"Downloading Chrome from {chrome_url}...")
        urllib.request.urlretrieve(chrome_url, installer_path)
        log.info(f"Chrome installer downloaded to {installer_path}")
        return True
    except Exception as e:
        log.error(f"Failed to download Chrome installer: {e}")
        return False

