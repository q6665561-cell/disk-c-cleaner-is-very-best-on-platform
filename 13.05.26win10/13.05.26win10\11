def main():
    """Main function to orchestrate the cleanup process."""
    log.info("="*60)
    log.info("Starting Professional Windows Deep Clean")
    log.info("="*60)

    # Safety Check: Must be run as Administrator
    if not is_admin():
        log.critical("This script must be run as Administrator. Exiting.")
        sys.exit(1)

    # Safety Check: Verify target build numbers
    try:
        import platform
        win_ver = platform.version()
        # Check for known build numbers. If you want to be strict, uncomment the following:
        # if win_ver not in ["10.0.19045", "10.0.26100"]:
        #     log.critical(f"Unsupported Windows version: {win_ver}. This script is only for builds 19045.7291 or 26100.8457.")
        #     sys.exit(1)
        log.info(f"Detected Windows Version: {win_ver}")
    except Exception as e:
        log.warning(f"Could not determine Windows version: {e}")

    # 1. Clean Temp Files
    clean_temp_files()

    # 2. Clean Windows Update Cache
    clean_windows_update_cache()

    # 3. Empty Recycle Bin
    empty_recycle_bin()

    # 4. Clean Browser Data
    clean_browser_cache()

    # 5. Run System Cleanup Tools
    run_system_cleanup_tools()

    # 6. Final Step: Check for browsers and download Chrome if needed
    if not is_any_browser_installed():
        log.warning("No browser detected. Proceeding to download Chrome installer.")
        success = download_chrome_installer()
        if not success:
            log.error("Failed to provide Chrome installer. Please manually install a browser.")
    else:
        log.info("A browser is installed. No need to download Chrome.")

    log.info("="*60)
    log.info("Deep Clean Completed Successfully!")
    log.info("A system restart is recommended for all changes to take effect.")
    log.info("="*60)

if __name__ == "__main__":
    main()
